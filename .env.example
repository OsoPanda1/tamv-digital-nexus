# TAMV Environment Variables Template
# Copy this file to .env and fill in the values

# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# ===========================================
# ODOO ERP INTEGRATION
# ===========================================
# TAMV Official Odoo: https://tamvonline-oficial.odoo.com
VITE_ODOO_BASE_URL="https://tamvonline-oficial.odoo.com"
VITE_ODOO_DB="tamvonline"
VITE_ODOO_USERNAME="your-username"
VITE_ODOO_API_KEY="your-api-key"

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================
VITE_APP_ENV="development"  # or "production"
VITE_APP_NAME="TAMV Digital Nexus"
VITE_APP_VERSION="1.0.0"

# ===========================================
# VERCEL DEPLOYMENT
# ===========================================
# For Vercel: https://v0-tamvonline-oficial.vercel.app/
# Connect GitHub repository to Vercel for automatic deployments
